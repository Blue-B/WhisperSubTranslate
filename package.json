{
  "name": "whispersubtranslate",
  "version": "2.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron --expose-gc .",
    "build": "electron-builder --publish never",
    "build-win": "electron-builder --win",
    "postinstall": "node scripts/postinstall.js",
    "test": "node scripts/smoke-test.js",
    "test:e2e": "node scripts/e2e-smoke.js",
    "lint": "eslint *.js locales/*.js --fix",
    "lint:check": "eslint *.js locales/*.js",
    "check": "npm run lint:check && npm test",
    "check:full": "npm run lint:check && npm test && npm run test:e2e",
    "format": "prettier --write \"*.js\" \"locales/*.js\" \"*.json\" \"*.html\" \"*.css\""
  },
  "keywords": [],
  "author": "GTPS Team",
  "license": "GPL-3.0",
  "description": "Whisper 기반 자막 추출·번역 도구 (whisper.cpp)",
  "build": {
    "appId": "com.whispersubtranslate.app",
    "productName": "WhisperSubTranslate",
    "directories": {
      "output": "dist2"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "icon.png",
      "assets/**",
      "locales/**",
      "renderer.js",
      "translator-enhanced.js",
      "lib/**",
      "local-translator.js",
      "myMemoryTranslator.js",
      "scripts/postinstall.js",
      "node_modules/**/*",
      "!node_modules/**/{*.md,*.markdown,LICENSE*,test,tests,__tests__,*.map}",
      "!node_modules/@node-llama-cpp/linux-*/**",
      "!node_modules/@node-llama-cpp/win-arm64/**",
      "!node_modules/ffprobe-static/bin/linux/**",
      "!node_modules/ffprobe-static/bin/darwin/**"
    ],
    "extraResources": [
      {
        "from": "nya.wav",
        "to": "nya.wav"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/ffprobe-static/**",
      "node_modules/node-llama-cpp/**",
      "node_modules/@node-llama-cpp/**"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp"
        },
        {
          "from": "ffprobe.exe",
          "to": "ffprobe.exe"
        }
      ]
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp",
          "filter": [
            "whisper-cli",
            "cpu/**",
            "*.so*"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "whisper-cpp",
          "to": "whisper-cpp",
          "filter": [
            "whisper-cli",
            "cpu/**",
            "*.dylib"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhisperSubTranslate"
    }
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.1.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "deepl-node": "^1.13.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "node-llama-cpp": "^3.18.1"
  },
  "optionalDependencies": {
    "@node-llama-cpp/linux-arm64": "3.18.1",
    "@node-llama-cpp/linux-armv7l": "3.18.1",
    "@node-llama-cpp/linux-x64": "3.18.1",
    "@node-llama-cpp/linux-x64-cuda": "3.18.1",
    "@node-llama-cpp/linux-x64-cuda-ext": "3.18.1",
    "@node-llama-cpp/linux-x64-vulkan": "3.18.1",
    "@node-llama-cpp/mac-arm64-metal": "3.18.1",
    "@node-llama-cpp/mac-x64": "3.18.1",
    "@node-llama-cpp/win-arm64": "3.18.1",
    "@node-llama-cpp/win-x64": "3.18.1",
    "@node-llama-cpp/win-x64-cuda": "3.18.1",
    "@node-llama-cpp/win-x64-cuda-ext": "3.18.1",
    "@node-llama-cpp/win-x64-vulkan": "3.18.1"
  }
}
